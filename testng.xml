<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="TestNG101 Suite" parallel="classes" thread-count="8">
    <listeners>
        <listener class-name="com.testng101.listeners.LogListener" />
    </listeners>
    <test name="Chrome Test">
        <parameter name="browser" value="Chrome"/>
        <parameter name="version" value="128.0"/>
        <parameter name="platform" value="Windows 10"/>
        <classes>
            <class name="com.testng101.tests.TestScenario1"/>
            <class name="com.testng101.tests.TestScenario2"/>
            <class name="com.testng101.tests.TestScenario3"/>
        </classes>
    </test>
    
    <test name="Edge Test">
        <parameter name="browser" value="MicrosoftEdge"/>
        <parameter name="version" value="127.0"/>
        <parameter name="platform" value="macOS Ventura"/>
        <classes>
            <class name="com.testng101.tests.TestScenario1"/>
            <class name="com.testng101.tests.TestScenario2"/>
            <class name="com.testng101.tests.TestScenario3"/>
        </classes>
    </test>
    
    <test name="Firefox Test">
        <parameter name="browser" value="Firefox"/>
        <parameter name="version" value="130.0"/>
        <parameter name="platform" value="Windows 11"/>
        <classes>
            <class name="com.testng101.tests.TestScenario1"/>
            <class name="com.testng101.tests.TestScenario2"/>
            <class name="com.testng101.tests.TestScenario3"/>
        </classes>
    </test>
    
    <test name="Internet Explorer Test">
        <parameter name="browser" value="Internet Explorer"/>
        <parameter name="version" value="11.0"/>
        <parameter name="platform" value="Windows 10"/>
        <classes>
            <class name="com.testng101.tests.TestScenario1"/>
            <class name="com.testng101.tests.TestScenario2"/>
            <class name="com.testng101.tests.TestScenario3"/>
        </classes>
    </test>
</suite>
